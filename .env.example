# Copy to ".env" in this folder and fill in from your Supabase project (Settings → API).
# Restart Expo (stop Metro and run `npx expo start` again) after changing env vars.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional: allow "Continue without SMS (dev)" even when Supabase is configured.
# In development, that button also appears automatically if Supabase keys are missing.
# Remove / set false before Play Store release.
# EXPO_PUBLIC_DEV_MOCK_AUTH=true
