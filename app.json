{
  "expo": {
    "name": "Hungry Tiger",
    "slug": "hungry-tiger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hungrytiger",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FCD200"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hungrytiger.app"
    },
    "android": {
      "package": "com.hungrytiger.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FCD200"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hungry Tiger uses your location to center the map when you choose your area.",
          "locationAlwaysAndWhenInUsePermission": "Hungry Tiger uses your location to center the map when you choose your area."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
